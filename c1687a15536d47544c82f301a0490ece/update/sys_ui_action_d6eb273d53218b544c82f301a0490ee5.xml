        <script><![CDATA[var existingGap = new GlideRecord('x_1920001_careeros_skill_gap');

existingGap.addQuery('profile', current.sys_id);
existingGap.addQuery('missing_skill', skillId);
existingGap.addQuery('status', '!=', 'completed');

existingGap.query();

if (!existingGap.hasNext()) {

    var gap = new GlideRecord('x_1920001_careeros_skill_gap');

    gap.initialize();

    gap.profile = current.sys_id;
    gap.target_role = current.target_role;
    gap.missing_skill = skillId;

    gap.priority = 'high';
    gap.status = 'open';

    gap.recommended_action =
        'Complete training for this skill';

    gap.insert();
}]]></script>
